{
  "name": "flippio",
  "version": "0.4.6",
  "description": "Database viewer with device connection",
  "author": "koliastanis",
  "homepage": "https://github.com/groot007/flippio",
  "sideEffects": false,
  "main": "./src-tauri/target/release/flippio",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "yarn typecheck:web",
    "dev:renderer": "cd src/renderer && vite",
    "build:renderer": "cd src/renderer && vite build",
    "build:renderer:e2e": "VITE_E2E_MODE=true npm run build:renderer",
    "build:e2e": "VITE_E2E_MODE=true cargo build --manifest-path src-tauri/Cargo.toml",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:e2e:prepare": "yarn build:renderer:e2e && yarn build:e2e",
    "test:e2e": "VITE_E2E_MODE=true yarn test:e2e:prepare && VITE_E2E_MODE=true wdio run ./wdio.conf.cjs",
    "test:e2e:clean": "VITE_E2E_MODE=true yarn test:e2e:prepare && WDIO_LOG_LEVEL=error VITE_E2E_MODE=true wdio run ./wdio.conf.cjs",
    "test:e2e:debug": "VITE_E2E_MODE=true yarn test:e2e:prepare && WDIO_LOG_LEVEL=info VITE_E2E_MODE=true wdio run ./wdio.conf.cjs",
    "test:rust": "cd src-tauri && cargo test",
    "test:all": "yarn test && yarn test:rust",
    "precommit": "yarn lint && yarn typecheck && yarn test:all",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug",
    "version:update": "node scripts/update-version.js"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.13.0",
    "@emotion/react": "^11.14.0",
    "@sentry/react": "^9.33.0",
    "@tanstack/react-query": "^5.74.7",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-log": "^2.5.1",
    "@uiw/react-json-view": "^2.0.0-alpha.30",
    "ag-grid-community": "^33.1.1",
    "ag-grid-react": "^33.1.1",
    "chakra-react-select": "^6.1.0",
    "date-fns": "^3.6.0",
    "json-edit-react": "^1.26.2",
    "next-themes": "^0.4.6",
    "react-icons": "^5.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.10.2",
    "@sentry/vite-plugin": "^3.2.3",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@wdio/cli": "^9.18.0",
    "@wdio/globals": "^9.18.0",
    "@wdio/local-runner": "^9.18.0",
    "@wdio/mocha-framework": "^9.18.0",
    "@wdio/spec-reporter": "^9.18.0",
    "@wdio/tauri-plugin": "^1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "3.2.4",
    "better-sqlite3": "12.2.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.20.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "expect-webdriverio": "^5.4.3",
    "fix-path": "^4.0.0",
    "webdriverio": "^9.29.1",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite3": "5.1.7",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.9"
  },
  "resolutions": {
    "@wdio/native-utils": "2.5.0"
  }
}
